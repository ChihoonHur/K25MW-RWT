      sec 39 -1.13329  -6.2377232148195     110.384 0.985714;
      sec 40 -1.082    -6.57117447995006    113.296 1.23;
      sec 41 -1.02694  -6.92318688195843    116.291 1.32329;
      sec 42 -0.971875 -7.28438340278898    119.286 1.41659;
      sec 43 -0.916813 -7.65476404244174    122.281 1.50988;
      sec 44 -0.86175  -8.03432880091667    125.276 1.60318;
