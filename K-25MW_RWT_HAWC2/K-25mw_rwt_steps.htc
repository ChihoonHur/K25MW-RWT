;  K-25MW-RWT
;
 begin simulation; 
   time_stop 1250.0 ;
   solvertype 2;    (newmark)
   on_no_convergence continue;
   convergence_limits 1000.0 1.0 1e-07;
   logfile ./log/K-25mw_rwt_steps.log;
   begin newmark; 
     deltat 0.01;
   end newmark;
 end simulation;
;
begin new_htc_structure;
  begin main_body; 
    name monopile;
    type timoschenko;
    nbodies 1;
    node_distribution c2_def;
    damping_posdef   0.0 0.0 0.0 0.000648967596893514 0.000630757668966274 0.000103  ; Tuned to have 2% log decrement in 1st 2 modes and one more that I believe is a torsion mode (cannot confirm)
    begin timoschenko_input; 
      filename ./data/K-25mw_monopile_st.dat;
      set 1 1;
    end timoschenko_input;
    begin c2_def; 
      nsec 10;
      sec 1 0 0 -0.00E+00 0 ;
      sec 2 0 0 -7.94E+00 0 ;
      sec 3 0 0 -1.59E+01 0 ;
      sec 4 0 0 -2.38E+01 0 ;
      sec 5 0 0 -3.18E+01 0 ;
      sec 6 0 0 -3.97E+01 0 ;
      sec 7 0 0 -4.77E+01 0 ;
      sec 8 0 0 -5.56E+01 0 ;
      sec 9 0 0 -6.36E+01 0 ;
      sec 10 0 0 -6.40E+01 0 ;
    end c2_def;
    concentrated_mass 10 0.0 0.0 0.0 100000.0 0.0 0.0 0.0;
  end main_body;
  begin main_body; 
    name tower;
    type timoschenko;
    nbodies 1;
    node_distribution c2_def;
    damping_posdef   0.0 0.0 0.0 0.00197390217260817 0.00196770029907402 0.00015  ; tuned to 2% log decrement on first 2 modes and some other one that I believe is torsion (not sure)
    begin timoschenko_input; 
      filename ./data/K-25MW_tower_st.dat;
      set 1 1;
    end timoschenko_input;
    begin c2_def; 
      nsec 31;
      sec 1 0 0 -0.00000000E+00 0 ;
      sec 2 0 0 -5.56286667E+00 0 ;
