      sec 13 -2.18882  -0.549379519776511   32.7589 -8.70667;
      sec 14 -2.18538  -0.668237025408457   36.1292 -8.44;
      sec 15 -2.15949  -0.7837388680316     39.1272 -8.21625;
      sec 16 -2.13361  -0.908447550662487   42.1253 -7.9925;
      sec 17 -2.10772  -1.04235937415416    45.1234 -7.76875;
      sec 18 -2.08184  -1.18546941150682    48.1214 -7.545;
      sec 19 -2.05595  -1.3377872097543     51.1195 -7.32125;
      sec 20 -2.03007  -1.49930260794146    54.1175 -7.0975;
      sec 21 -2.00418  -1.67002053306809    57.1155 -6.87375;
      sec 22 -1.9783   -1.84994713996639    60.1136 -6.65;
      sec 23 -1.93579  -2.04488371514779    63.2015 -5.874;
