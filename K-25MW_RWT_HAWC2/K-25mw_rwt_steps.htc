      sec 23 0 0 -1.22383067E+02 0 ;
      sec 24 0 0 -1.27945933E+02 0 ;
      sec 25 0 0 -1.33508800E+02 0 ;
      sec 26 0 0 -1.39071667E+02 0 ;
      sec 27 0 0 -1.44634533E+02 0 ;
      sec 28 0 0 -1.50197400E+02 0 ;
      sec 29 0 0 -1.55760267E+02 0 ;
      sec 30 0 0 -1.61323133E+02 0 ;
      sec 31 0 0 -1.66886000E+02 0 ;
    end c2_def;
  end main_body;
  begin main_body; 
