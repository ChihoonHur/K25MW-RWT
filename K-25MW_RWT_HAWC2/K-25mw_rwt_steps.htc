    concentrated_mass   1   0.000000  -5.329918   6.436083 4.693537838E+04 1.071346038E+05 1.082545545E+05 2.085050649E+05 0.000000000E+00 0.000000000e+00 0.000000000E+00 ; mb2
    concentrated_mass   1   0.000000  -5.398604   7.089592 5.338000000E+03 1.830745600E+04 1.846043680E+04 3.215536625E+04 0.000000000E+00 0.000000000e+00 0.000000000E+00 ; lss
    concentrated_mass   1   0.000000  -0.000000   1.013552 3.905234288e+04 1.968628605e+04 1.968628605e+04 3.937257209e+04 0.000000000e+00 0.000000000e+00 0.000000000e+00 ; brake(22MW DATA)
    concentrated_mass   1   0.000000  -5.947490  12.311894 5.620564865E+04 1.071346038E+05 1.082545545E+05 2.085050649E+05 0.000000000E+00 0.000000000e+00 0.000000000E+00 ; hub system
  end main_body;
  begin main_body; 
    name connector;
    type timoschenko;
    nbodies 1;
    node_distribution c2_def;
    begin timoschenko_input; 
      filename ./data/K-25MW_connector_st.dat;
      set 1 1;
    end timoschenko_input;
    begin c2_def; 
      nsec 2;
      sec 1 0.0 0.0 0.00000000000000000e+00 0.0 ;
      sec 2 0.0 0.0 7.94700000000000006e+00 0.0 ;
    end c2_def;
  end main_body;
  begin main_body; 
    name shaft;
    type timoschenko;
    nbodies 1;
    node_distribution c2_def;
    begin timoschenko_input; 
      filename ./data/K-25MW_shaft_st.dat;
      set 1 1;
    end timoschenko_input;
    begin c2_def; 
      nsec 2;
      sec 1 0.0 0.0 0.00000000000000000e+00 0.0 ;
      sec 2 0.0 0.0 6.12999999999999989e+00 0.0 ;
    end c2_def;
  end main_body;
  begin main_body; 
    name hub1;
    type timoschenko;
    nbodies 1;
    node_distribution c2_def;
    begin timoschenko_input; 
      filename ./data/K-25MW_hub1_st.dat;
      set 1 1;
    end timoschenko_input;
    begin c2_def; 
      nsec 2;
      sec 1 0.0 0.0 0.00000000000000000e+00 0.0 ;
      sec 2 0.0 0.0 5.00000000000000018e+00 0.0 ;
    end c2_def;
  end main_body;
  begin main_body; 
    name hub2;
    copy_main_body hub1;
  end main_body;
  begin main_body; 
    name hub3;
    copy_main_body hub1;
  end main_body;
  begin main_body; 
    name blade1;
    type timoschenko;
    nbodies 52;
    node_distribution c2_def;
     damping_aniso_v2   0.0 0.0 0.0 0.00232711776894188 0.00459426345438474 0.000875  ; tuned to 2% log decrement for the first 2 modes
    begin timoschenko_input; 
       filename ./data/K-25MW_blade_fpm_st.dat ;
      set 1 1;
       FPM 1;
    end timoschenko_input;
    begin c2_def; 
      nsec 53;
      sec 1 0.0         0.0                 0.0 -11;
      sec 2 0.0        -0.00480012540659168 3.0621 -11;
      sec 3 0.0        -0.014366387535335   5.29745 -11;
      sec 4 0.0        -0.0290487011380179  7.5328 -11;
